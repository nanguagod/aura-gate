<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auragate.rbac.mapper.RoleMapper">

    <resultMap id="RoleResult" type="Role">
        <id property="roleId" column="id"/>
        <result property="roleName" column="role_name"/>
        <result property="roleKey" column="role_key"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!--查询角色列表-->
    <select id="selectRoleList" resultMap="RoleResult" parameterType="Role">
        select id, role_name, role_key, create_time
        from role
        <where>
            <if test="roleId != null">
                and id = #{roleId}
            </if>
            <if test="roleName != null and roleName != ''">
                and role_name like concat('%', #{roleName} ,'%')
            </if>
        </where>
        order by id
    </select>

    <!--根据角色ID查询角色信息-->
    <select id="selectRoleByRoleId" resultMap="RoleResult" parameterType="Long">
        select id, role_name, role_key, create_time
        from role
        where id = #{roleId}
    </select>

    <!--新增角色-->
    <insert id="insertRole" parameterType="Role" useGeneratedKeys="true" keyProperty="roleId">
        insert into role
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="roleId != null">id,</if>
            <if test="roleName != null and roleName != ''">role_name,</if>
            <if test="roleKey != null">role_key,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="roleId != null">#{roleId},</if>
            <if test="roleName != null and roleName != ''">#{roleName},</if>
            <if test="roleKey != null">#{roleKey},</if>
        </trim>
    </insert>

    <!--修改角色-->
    <update id="updateRole" parameterType="Role">
        update role
        <set>
            <if test="roleName != null and roleName != ''">role_name = #{roleName},</if>
            <if test="roleKey != null">role_key = #{roleKey},</if>
        </set>
        where id = #{roleId}
    </update>

    <!--删除角色-->
    <delete id="deleteRoleByRoleIds" parameterType="Long">
        delete from role
        where id in
        <foreach collection="array" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </delete>

</mapper>
