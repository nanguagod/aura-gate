<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auragate.rbac.mapper.MenuMapper">
    <resultMap id="MenuResult" type="Menu">
        <id property="menuId" column="id"/>
        <result property="menuName" column="menu_name"/>
        <result property="parentId" column="parent_id"/>
        <result property="menuSort" column="order_num"/>
        <result property="path" column="path"/>
        <result property="component" column="component"/>
        <result property="menuType" column="menu_type"/>
        <result property="perms" column="perms"/>
        <result property="icon" column="icon"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!--根据用户ID查询菜单列表-->
    <select id="selectMenuListByUserId" resultMap="MenuResult" parameterType="Menu">
        select m.id, m.menu_name, m.parent_id, m.order_num, m.path, m.component,
               m.menu_type, m.perms, m.icon, m.create_time
        from menu m
        left join role_menu rm on m.id = rm.menu_id
        left join user_role ur on rm.role_id = ur.role_id
        <where>
            <if test="userId != null">
                and ur.user_id = #{userId}
            </if>
            <if test="menuName != null and menuName != ''">
                and m.menu_name like concat('%', #{menuName} ,'%')
            </if>
        </where>
        order by m.order_num
    </select>

    <!--根据菜单ID查询菜单信息-->
    <select id="selectMenuByMenuId" resultMap="MenuResult" parameterType="Long">
        select id, menu_name, parent_id, order_num, path, component,
               menu_type, perms, icon, create_time
        from menu
        where id = #{menuId}
    </select>

    <!--新增菜单-->
    <insert id="insertMenu" parameterType="Menu" useGeneratedKeys="true" keyProperty="menuId">
        insert into menu
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="menuId != null">id,</if>
            <if test="menuName != null and menuName != ''">menu_name,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="menuSort != null">order_num,</if>
            <if test="path != null and path != ''">path,</if>
            <if test="component != null and component != ''">component,</if>
            <if test="menuType != null and menuType != ''">menu_type,</if>
            <if test="icon != null and icon != ''">icon,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="menuId != null">#{menuId},</if>
            <if test="menuName != null and menuName != ''">#{menuName},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="menuSort != null">#{menuSort},</if>
            <if test="path != null and path != ''">#{path},</if>
            <if test="component != null and component != ''">#{component},</if>
            <if test="menuType != null and menuType != ''">#{menuType},</if>
            <if test="icon != null and icon != ''">#{icon},</if>
        </trim>
    </insert>

    <!--修改菜单-->
    <update id="updateMenu" parameterType="Menu">
        update menu
        <set>
            <if test="menuName != null and menuName != ''">menu_name = #{menuName},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="menuSort != null">order_num = #{menuSort},</if>
            <if test="path != null and path != ''">path = #{path},</if>
            <if test="component != null and component != ''">component = #{component},</if>
            <if test="menuType != null and menuType != ''">menu_type = #{menuType},</if>
            <if test="icon != null and icon != ''">icon = #{icon},</if>
        </set>
        where id = #{menuId}
    </update>

    <!--删除菜单-->
    <delete id="deleteMenuByMenuId" parameterType="Long">
        delete from menu
        where id = #{menuId}
    </delete>

    <!--根据角色ID查询对应菜单树-->
    <select id="selectMenuListByRoleId" resultType="Long">
        select m.id
        from menu m
        left join role_menu rm on m.id = rm.menu_id
        where rm.role_id = #{roleId}
        order by m.parent_id, m.order_num
    </select>

</mapper>
